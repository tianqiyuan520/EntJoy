  </ImportGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgMicrosoft_NET_ILLink_Tasks Condition=" '$(PkgMicrosoft_NET_ILLink_Tasks)' == '' ">C:\Users\tianqiyuan520\.nuget\packages\microsoft.net.illink.tasks\8.0.19</PkgMicrosoft_NET_ILLink_Tasks>
